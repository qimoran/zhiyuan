# Docker Compose 标识。
# 默认值用于兼容当前已有的大数据本地环境。
BIGDATA_COMPOSE_PROJECT=zhitu-bigdata
CONTAINER_PREFIX=zhitu
IMAGE_PREFIX=zhitu
COMPOSE_IGNORE_ORPHANS=true

# 本地数据目录。
# 同学可以保留项目内相对路径，也可以改成自己电脑上的 D 盘路径。
BIGDATA_DOCKER_DATA=./.docker-data

# 宿主机端口。
MYSQL_PORT=13306
REDIS_PORT=16379
HDFS_NAMENODE_RPC_PORT=9000
HDFS_NAMENODE_WEB_PORT=9870
HDFS_DATANODE_WEB_PORT=9864
YARN_RESOURCEMANAGER_WEB_PORT=8088
YARN_NODEMANAGER_WEB_PORT=8042
HIVE_METASTORE_PORT=9083
HIVE_SERVER2_PORT=10000
HIVE_SERVER2_WEB_PORT=10002
SPARK_MASTER_PORT=7077
SPARK_MASTER_WEB_PORT=18080
SPARK_WORKER_WEB_PORT=18081

# 开发数据库账号配置。
MYSQL_ROOT_PASSWORD=root123456
HIVE_DB_USER=hive
HIVE_DB_PASSWORD=hive123456
ZHIYUAN_DB_NAME=zhiyuan
ZHIYUAN_DB_USER=zhiyuan_app
ZHIYUAN_DB_PASSWORD=zhiyuan123456

# 容器运行时访问地址。
MYSQL_HOST=mysql
REDIS_HOST=redis
HADOOP_FS=hdfs://namenode:9000
SPARK_MASTER=spark://spark-master:7077

# 可选构建代理。只有 Docker build 下载慢或被阻断时才需要填写。
HTTP_PROXY=
HTTPS_PROXY=
NO_PROXY=localhost,127.0.0.1,mysql,redis,namenode,datanode,resourcemanager,nodemanager,hive-metastore,hiveserver2,spark-master,spark-worker,python

# 大模型配置。推荐默认使用 AnyRouter 的 Anthropic Messages；不配置 Key 时自动使用模板兜底。
LLM_API_KEY=
LLM_PROVIDER=anthropic
LLM_BASE_URL=https://anyrouter.top/v1
LLM_MODEL=claude-haiku-4-5-20251001
LLM_TIMEOUT_SECONDS=30
LLM_TEMPERATURE=0.2

# 推荐资料核验智能体配置。
# 本地 RAG 默认读取 data/rag 下的 PDF，也会优先使用 source_documents.local_path 登记的 PDF。
RECOMMEND_AGENT_ENABLED=true
LOCAL_RAG_ENABLED=true
RECOMMEND_RAG_DIR=data/rag
LOCAL_RAG_TOP_K=3

# Tavily 联网搜索配置。不填写 TAVILY_API_KEY 时自动跳过联网搜索。
TAVILY_SEARCH_ENABLED=true
TAVILY_API_KEY=
TAVILY_API_URL=https://api.tavily.com/search
TAVILY_TOP_K=3
TAVILY_TIMEOUT_SECONDS=12
